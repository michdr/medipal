{
  "providers": {
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "baseURL": "${OPENROUTER_BASE_URL}"
    },
    "groq": {
      "apiKey": "${GROQ_API_KEY}"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "provider": "openrouter",
      "model": "openai/gpt-4o",
      "temperature": 0.1
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["*"]
    }
  }
}
